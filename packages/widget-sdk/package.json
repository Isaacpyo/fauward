{
  "name": "@fauward/widget-sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Embeddable widget SDK — compiles to public embed.js",
  "scripts": {
    "build": "esbuild src/embed.ts --bundle --minify --format=iife --outfile=dist/embed.js --platform=browser",
    "build:dev": "esbuild src/embed.ts --bundle --format=iife --outfile=dist/embed.dev.js --platform=browser --sourcemap"
  },
  "devDependencies": {
    "esbuild": "^0.21.5",
    "typescript": "^5.7.2"
  }
}
