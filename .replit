run = "cd apps/frontend && npm install && npm run dev"
entrypoint = "apps/frontend/src/app/page.tsx"
hidden = [".next", "node_modules"]
modules = ["nodejs-20"]

[nix]
channel = "stable-24_05"

[deployment]
run = ["bash", "scripts/start.sh"]
deploymentTarget = "autoscale"
build = ["bash", "scripts/build.sh"]

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5173
externalPort = 5173

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Tenant Portal"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Super Admin"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/frontend && npm install && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/backend && npm install && npm run dev"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Tenant Portal"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/tenant-portal && npm install && npm run dev"
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Super Admin"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/super-admin && npm install && npm run dev"
waitForPort = 5173
