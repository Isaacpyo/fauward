{
  "name": "fauward",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@fauward/backend --filter=@fauward/frontend --filter=@fauward/tenant-portal --filter=@fauward/super-admin",
    "dev:all": "turbo run dev",
    "dev:backend": "turbo run dev --filter=@fauward/backend",
    "dev:frontend": "turbo run dev --filter=@fauward/frontend --filter=@fauward/tenant-portal",
    "build": "turbo run build",
    "start": "npm run start --workspace=apps/backend",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "serve": "^14.2.6"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  }
}
