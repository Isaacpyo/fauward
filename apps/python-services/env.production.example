# Fauward Python Services - production template
#
# Do not commit real production values. Store these in the deployment
# platform secret manager, CI/CD variables, or the host's private env file.

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require
REDIS_URL=rediss://default:TOKEN@HOST:PORT

SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

SENDGRID_API_KEY=replace_with_sendgrid_api_key
TWILIO_ACCOUNT_SID=replace_with_twilio_account_sid
TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
TWILIO_FROM=+10000000000

OSRM_BASE_URL=https://osrm.your-domain.example
PYTHON_QUEUE_LISTENERS_ENABLED=true
PYTHON_LOCAL_STORAGE_DIR=.storage
PYTHON_DEFAULT_EMAIL_FROM=no-reply@fauward.com
LOG_LEVEL=INFO

# Docker Compose production deployments may prefer Python-specific aliases
# to avoid inheriting backend-local DATABASE_URL or REDIS_URL values.
PYTHON_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB?sslmode=require
PYTHON_REDIS_URL=rediss://default:TOKEN@HOST:PORT
