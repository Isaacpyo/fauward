# Fauward Python Services - host-local development
#
# Copy this file to apps/python-services/.env when running uvicorn/celery
# directly on your machine.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fauward_dev
REDIS_URL=redis://localhost:6379/0

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

OSRM_BASE_URL=http://router.project-osrm.org
PYTHON_QUEUE_LISTENERS_ENABLED=true
PYTHON_LOCAL_STORAGE_DIR=.storage
PYTHON_DEFAULT_EMAIL_FROM=no-reply@fauward.com
LOG_LEVEL=INFO
