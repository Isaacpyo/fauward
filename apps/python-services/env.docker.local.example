# Fauward Python Services - local Docker Compose
#
# Use from the repo root:
# docker compose --env-file apps/python-services/env.docker.local.example up --build python-api python-worker python-beat
#
# These PYTHON_* values are mapped into DATABASE_URL and REDIS_URL by
# docker-compose.yml for the Python containers.

PYTHON_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/fauward_dev
PYTHON_REDIS_URL=redis://redis:6379

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

OSRM_BASE_URL=http://router.project-osrm.org
PYTHON_LOCAL_STORAGE_DIR=.storage
PYTHON_DEFAULT_EMAIL_FROM=no-reply@fauward.com
LOG_LEVEL=INFO
